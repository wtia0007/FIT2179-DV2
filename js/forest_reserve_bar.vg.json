{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Forest Reserve by State (2019)",
    "width": 600,
    "height": 300,
    "data": {"url": "data/forest_reserve_state.csv"},
    "transform": [
      {"filter": "year(datum.date) == 2019"},
      {"filter": "datum.state != 'Semenanjung Malaysia'"}
    ],
    "mark": {"type": "bar", "color": "#2d6a4f"},
    "encoding": {
      "y": {"field": "state", "type": "nominal", "sort": "-x", "title": "State"},
      "x": {"field": "area", "type": "quantitative", "title": "Area (ha)"}
    }
  }
